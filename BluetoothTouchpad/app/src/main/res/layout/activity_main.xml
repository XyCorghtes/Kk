<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <!-- Status bar -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213e"
        android:padding="12dp"
        android:text="初始化中..."
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Touch pad area -->
    <View
        android:id="@+id/touchView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0f3460"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintBottom_toTopOf="@id/connectButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Connect button -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#e94560"
        android:text="等待连接"
        android:textColor="#ffffff"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Instructions overlay -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="触摸区域作为触控板\n支持多点触控"
        android:textColor="#a0a0a0"
        android:textSize="16sp"
        android:gravity="center"
        android:alpha="0.7"
        app:layout_constraintTop_toTopOf="@id/touchView"
        app:layout_constraintBottom_toBottomOf="@id/touchView"
        app:layout_constraintStart_toStartOf="@id/touchView"
        app:layout_constraintEnd_toEndOf="@id/touchView" />

</androidx.constraintlayout.widget.ConstraintLayout>
